{
  "name": "circuits-app",
  "private": true,
  "version": "1.0.0",
  "description": "Interactive educational app for learning electrical circuits — 145 lessons, quizzes, real-time simulation, and a sandbox.",
  "homepage": "https://majestic-owl448.github.io/circuits-app/",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify:engine": "node --experimental-strip-types src/engine/__fixtures__/run-fixtures.ts",
    "verify:engine:mna": "node --experimental-strip-types src/engine/__fixtures__/run-mna-fixtures.ts",
    "verify:engine:compare": "CIRCUITS_SOLVER_BACKEND=compare node --experimental-strip-types src/engine/__fixtures__/run-fixtures.ts",
    "verify:evaluator": "node --experimental-strip-types src/engine/__fixtures__/run-evaluator-fixtures.ts"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
